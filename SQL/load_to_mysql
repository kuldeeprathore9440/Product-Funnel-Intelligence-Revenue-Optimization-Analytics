   "source": [
    "import pandas as pd\n",
    "from sqlalchemy import create_engine, text\n",
    "from sqlalchemy.engine import URL\n",
    "\n",
    "MYSQL_USER = \"root\"\n",
    "MYSQL_PASSWORD = \"kr9440\"\n",
    "MYSQL_HOST = \"localhost\"\n",
    "MYSQL_PORT = 3306\n",
    "DB_NAME = \"funnel_analytics\"\n",
    "\n",
    "USERS_FILE = r\"C:\\Users\\kuldiep\\Downloads\\Data\\users_clean.csv\"\n",
    "EVENTS_FILE = r\"C:\\Users\\kuldiep\\Downloads\\Data\\events_clean.csv\"\n",
    "ORDERS_FILE = r\"C:\\Users\\kuldiep\\Downloads\\Data\\orders_clean.csv\"\n",
    "FUNNEL_FILE = r\"C:\\Users\\kuldiep\\Downloads\\Data\\funnel_user_summary.csv\"\n",
    "\n",
    "# Server connection (without database name)\n",
    "server_url = URL.create(\n",
    "    drivername=\"mysql+pymysql\",\n",
    "    username=MYSQL_USER,\n",
    "    password=MYSQL_PASSWORD,\n",
    "    host=MYSQL_HOST,\n",
    "    port=MYSQL_PORT,\n",
    ")\n",
    "\n",
    "server_engine = create_engine(server_url)\n",
    "\n",
    "with server_engine.connect() as conn:\n",
    "    conn.execute(text(f\"CREATE DATABASE IF NOT EXISTS {DB_NAME}\"))\n",
    "    conn.commit()\n",
    "\n",
    "# Database connection\n",
    "db_url = URL.create(\n",
    "    drivername=\"mysql+pymysql\",\n",
    "    username=MYSQL_USER,\n",
    "    password=MYSQL_PASSWORD,\n",
    "    host=MYSQL_HOST,\n",
    "    port=MYSQL_PORT,\n",
    "    database=DB_NAME,\n",
    ")\n",
    "\n",
    "db_engine = create_engine(db_url)\n",
    "\n",
    "# Read CSV files\n",
    "users = pd.read_csv(USERS_FILE)\n",
    "events = pd.read_csv(EVENTS_FILE)\n",
    "orders = pd.read_csv(ORDERS_FILE)\n",
    "funnel = pd.read_csv(FUNNEL_FILE)\n",
    "\n",
    "# Convert data types\n",
    "users[\"signup_date\"] = pd.to_datetime(users[\"signup_date\"], errors=\"coerce\")\n",
    "events[\"timestamp\"] = pd.to_datetime(events[\"timestamp\"], errors=\"coerce\")\n",
    "orders[\"order_date\"] = pd.to_datetime(orders[\"order_date\"], errors=\"coerce\")\n",
    "orders[\"order_value\"] = pd.to_numeric(orders[\"order_value\"], errors=\"coerce\")\n",
    "\n",
    "date_cols = [\n",
    "    \"signup_date\",\n",
    "    \"visit_time\",\n",
    "    \"signup_time\",\n",
    "    \"activate_time\",\n",
    "    \"add_to_cart_time\",\n",
    "    \"purchase_time\",\n",
    "    \"first_order_date\"\n",
    "]\n",
    "\n",
    "for col in date_cols:\n",
    "    if col in funnel.columns:\n",
    "        funnel[col] = pd.to_datetime(funnel[col], errors=\"coerce\")\n",
    "\n",
    "numeric_cols = [\n",
    "    \"visit_flag\", \"signup_flag\", \"activate_flag\", \"add_to_cart_flag\", \"purchase_flag\",\n",
    "    \"total_orders\", \"total_revenue\", \"avg_order_value\",\n",
    "    \"days_visit_to_signup\", \"days_signup_to_activate\", \"days_activate_to_cart\",\n",
    "    \"days_cart_to_purchase\", \"days_visit_to_purchase\", \"converted_user\"\n",
    "]\n",
    "\n",
    "for col in numeric_cols:\n",
    "    if col in funnel.columns:\n",
    "        funnel[col] = pd.to_numeric(funnel[col], errors=\"coerce\")\n",
    "\n",
    "# Create tables\n",
    "create_users_table = \"\"\"\n",
    "CREATE TABLE IF NOT EXISTS users (\n",
    "    user_id BIGINT PRIMARY KEY,\n",
    "    signup_date DATETIME,\n",
    "    country VARCHAR(100),\n",
    "    device VARCHAR(50),\n",
    "    channel VARCHAR(100)\n",
    ");\n",
    "\"\"\"\n",
    "\n",
    "create_events_table = \"\"\"\n",
    "CREATE TABLE IF NOT EXISTS events (\n",
    "    id BIGINT AUTO_INCREMENT PRIMARY KEY,\n",
    "    user_id BIGINT,\n",
    "    event VARCHAR(50),\n",
    "    timestamp DATETIME\n",
    ");\n",
    "\"\"\"\n",
    "\n",
    "create_orders_table = \"\"\"\n",
    "CREATE TABLE IF NOT EXISTS orders (\n",
    "    order_id BIGINT PRIMARY KEY,\n",
    "    user_id BIGINT,\n",
    "    order_value DECIMAL(12,2),\n",
    "    order_date DATETIME\n",
    ");\n",
    "\"\"\"\n",
    "\n",
    "create_funnel_table = \"\"\"\n",
    "CREATE TABLE IF NOT EXISTS funnel_user_summary (\n",
    "    user_id BIGINT PRIMARY KEY,\n",
    "    signup_date DATETIME,\n",
    "    country VARCHAR(100),\n",
    "    device VARCHAR(50),\n",
    "    channel VARCHAR(100),\n",
    "    visit_time DATETIME,\n",
    "    signup_time DATETIME,\n",
    "    activate_time DATETIME,\n",
    "    add_to_cart_time DATETIME,\n",
    "    purchase_time DATETIME,\n",
    "    visit_flag INT,\n",
    "    signup_flag INT,\n",
    "    activate_flag INT,\n",
    "    add_to_cart_flag INT,\n",
    "    purchase_flag INT,\n",
    "    total_orders INT,\n",
    "    total_revenue DECIMAL(12,2),\n",
    "    avg_order_value DECIMAL(12,2),\n",
    "    first_order_date DATETIME,\n",
    "    days_visit_to_signup INT,\n",
    "    days_signup_to_activate INT,\n",
    "    days_activate_to_cart INT,\n",
    "    days_cart_to_purchase INT,\n",
    "    days_visit_to_purchase INT,\n",
    "    converted_user INT,\n",
    "    max_stage_reached VARCHAR(50),\n",
    "    revenue_segment VARCHAR(50)\n",
    ");\n",
    "\"\"\"\n",
    "\n",
    "with db_engine.connect() as conn:\n",
    "    conn.execute(text(create_users_table))\n",
    "    conn.execute(text(create_events_table))\n",
    "    conn.execute(text(create_orders_table))\n",
    "    conn.execute(text(create_funnel_table))\n",
    "    conn.commit()\n",
    "\n",
    "# Clear old data\n",
    "with db_engine.connect() as conn:\n",
    "    conn.execute(text(\"DELETE FROM events\"))\n",
    "    conn.execute(text(\"DELETE FROM orders\"))\n",
    "    conn.execute(text(\"DELETE FROM funnel_user_summary\"))\n",
    "    conn.execute(text(\"DELETE FROM users\"))\n",
    "    conn.commit()\n",
    "\n",
    "# Insert data\n",
    "users.to_sql(\"users\", con=db_engine, if_exists=\"append\", index=False, method=\"multi\", chunksize=5000)\n",
    "events.to_sql(\"events\", con=db_engine, if_exists=\"append\", index=False, method=\"multi\", chunksize=10000)\n",
    "orders.to_sql(\"orders\", con=db_engine, if_exists=\"append\", index=False, method=\"multi\", chunksize=5000)\n",
    "funnel.to_sql(\"funnel_user_summary\", con=db_engine, if_exists=\"append\", index=False, method=\"multi\", chunksize=5000)\n",
    "\n",
    "print(\"Data inserted successfully.\")"
   ]
  },
